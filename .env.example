# Optional: keep mock mode by leaving these blank.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Optional: public URL to your own server/edge function that performs AI summaries.
# The mobile app calls this endpoint; it must NOT contain your OpenAI secret.
EXPO_PUBLIC_AI_SUMMARY_ENDPOINT=

# Server-side only. Do not expose this with an EXPO_PUBLIC_ prefix.
# Put this in your API server/Supabase Edge Function secrets, not in the client app bundle.
OPENAI_API_KEY=
